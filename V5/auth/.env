# auth/.env
# API Credentials
KITE_API_KEY="your_api_key_here"
KITE_ACCESS_TOKEN="your_access_token_here"

# Strategy Flags
STRADDLE_FLAG="False"
STRANGLE_FLAG="True"

# Strategy Parameters
BIAS="0"
ADJACENCY_GAP="100"
PROFIT_POINTS="250"
SHUTDOWN_LOSS="12.5"

# Order Parameters
HEDGE_ONE_LOT="False"
BUY_HEDGE="True"
FAR_SELL_ADD="True"
LOT_SIZE="50"

# Operational Config
CHECK_INTERVAL="300"
